# =============================================================================
# Daytona Local Environment — docker/.env
# =============================================================================
# Only secrets, credentials, and external URLs that contain the WSL2 IP.
# Static internal Docker URLs are hardcoded in docker-compose.local.yaml.
# Update WSL2_IP if your WSL2 IP changes: wsl hostname -I
# =============================================================================

# -----------------------------------------------------------------------------
# WSL2 — update if IP changes
# -----------------------------------------------------------------------------
WSL2_IP=192.168.16.153

# -----------------------------------------------------------------------------
# Secrets & API keys
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=supersecretkey
ENCRYPTION_SALT=supersecretsalt
PROXY_API_KEY=super_secret_key
RUNNER_API_KEY=secret_api_token
SSH_GATEWAY_API_KEY=ssh_secret_api_token
HEALTH_CHECK_API_KEY=supersecretkey

# -----------------------------------------------------------------------------
# Database credentials (shared postgres-shared)
# -----------------------------------------------------------------------------
DB_USERNAME=admin
DB_PASSWORD=admin
DB_DATABASE=daytona

# -----------------------------------------------------------------------------
# MinIO credentials (shared minio-shared)
# -----------------------------------------------------------------------------
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# SMTP sender identity
# -----------------------------------------------------------------------------
SMTP_EMAIL_FROM=Daytona Team <no-reply@learner.io>

# -----------------------------------------------------------------------------
# External URLs — contain WSL2 IP, visible from Windows browser
# -----------------------------------------------------------------------------
DASHBOARD_URL=http://192.168.16.153:12000/dashboard
DASHBOARD_BASE_API_URL=http://192.168.16.153:12000
PUBLIC_OIDC_DOMAIN=http://192.168.16.153:13300/dex
SSH_GATEWAY_URL=192.168.16.153:12150
SSH_GATEWAY_COMMAND=ssh -p 12150 {{TOKEN}}@192.168.16.153
